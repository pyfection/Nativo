.git
.github
.venv
.idea
.vscode
.claude
.pytest_cache
.ruff_cache
__pycache__
*.pyc

# NOTE: this single .dockerignore applies to BOTH images — the backend and
# frontend Dockerfiles share the repo root as build context. Do not exclude
# `frontend` here: Dockerfile.frontend COPYs frontend/package.json from the
# context and fails with ENOENT if it's ignored. The backend image is
# unaffected by its presence (it only COPYs pyproject/uv.lock/backend).
**/node_modules
frontend/dist

# Dev artifacts
backend/uploads
backend/nativo.db
*.sqlite
*.sqlite3
*.db

# Local env
.env
.env.local
**/.env
!**/.env.example

# Docs / repo meta
*.md
!README.md
docker-compose*.yml
docker
